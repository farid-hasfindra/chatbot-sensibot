datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Needed for Prisma + Vercel/Neon connection pooling
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  image         String?
  systemPrompt  String?   @db.Text
  conversations Conversation[]
  customPersonas CustomPersona[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CustomPersona {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  prompt    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Conversation {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" or "assistant"
  content        String
  tokens         Int?         // to store usage tokens for assistant
  model          String?      // to store model name for assistant
  isRag          Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model RateLimit {
  id         String   @id @default(cuid())
  identifier String   // UserID (jika login) atau Alamat IP (jika Guest)
  date       String   // Tanggal dengan format YYYY-MM-DD
  count      Int      @default(0)

  @@unique([identifier, date])
}
